# ============================================================================
# Environment variables template
# ============================================================================
# Copy this file to `.env` for local development (never commit `.env`).
# For production, set these values in Vercel Dashboard → Project → Settings →
# Environment Variables.
# ============================================================================

# ---- Optional: API keys for server-side proxies (api/proxy/*.js) ----
# Set these ONLY in Vercel environment variables — never commit actual values.

# Claude / Anthropic API
ANTHROPIC_API_KEY=

# OpenAI API
OPENAI_API_KEY=

# SendGrid (email)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Resend (email)
RESEND_API_KEY=

# ---- Application-wide secrets ----

# Secret used to sign short-lived API proxy tokens (any random 32+ chars)
API_PROXY_SIGNING_SECRET=

# Rate limit: max requests per minute per user for proxied APIs
API_RATE_LIMIT_PER_MINUTE=60

# ---- Optional: allowed origins for CORS on API routes ----
# Defaults to the Vercel deployment URL if not set
ALLOWED_ORIGINS=https://your-custom-domain.example.com
